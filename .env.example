CORUSCANT_DATA_DIR=data
CORUSCANT_CONFIG_DIR=config
CORUSCANT_DATABASE_URL=sqlite:///data/coruscant.db

# Auth — REQUIRED in any real deployment. If unset, an ephemeral per-process
# secret is generated (tokens reset on restart). Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CORUSCANT_SECRET_KEY=

# Restrict CORS to your web origin(s) (JSON list). Defaults to ["*"].
# CORUSCANT_CORS_ORIGINS=["http://localhost:8080"]

# Demo account seeding is OFF by default. For a local demo only, opt in and set
# a password (the docker-compose stack does this for you):
# CORUSCANT_SEED_DEMO_USER=true
# CORUSCANT_DEMO_PASSWORD=change-me

# Expose password-reset tokens in the API response (offline/dev only; never prod).
# CORUSCANT_EXPOSE_RESET_TOKEN=false

# --- Live ingestion (production) -------------------------------------------
# Sources that use their real network connector instead of the offline reference
# connector (JSON list). Empty by default → dev/test stay fully offline. Only
# sec_edgar currently has a live connector. For the live path to fetch anything,
# the relevant companies must declare `sec_filings:` URLs in config/companies.yml.
# CORUSCANT_LIVE_SOURCES=["sec_edgar"]

# SEC requires a contact-bearing User-Agent on every request.
# CORUSCANT_EDGAR_USER_AGENT=YourCompany/1.0 you@example.com

# SEC fair-access cap (requests/second; SEC permits ~10). Applies to live EDGAR.
# CORUSCANT_SEC_RATE_LIMIT_PER_SECOND=8

# Live equity quotes for the World tab "since yesterday" (free Yahoo Finance,
# unofficial/not real-time). OFF by default so offline/test never hits the
# network; when off, /portfolio/prices reports connected=false (never faked).
# CORUSCANT_ENABLE_LIVE_PRICES=true

# --- Multi-tenant quota enforcement ----------------------------------------
# Enforce per-plan daily API + watchlist limits. Only takes effect when an
# organization store is configured (a multi-tenant deployment); single-tenant
# use is never throttled. Set false to disable.
# CORUSCANT_ENFORCE_QUOTAS=true
