CORUSCANT_DATA_DIR=data
CORUSCANT_CONFIG_DIR=config
CORUSCANT_DATABASE_URL=sqlite:///data/coruscant.db

# Auth — REQUIRED in any real deployment. If unset, an ephemeral per-process
# secret is generated (tokens reset on restart). Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CORUSCANT_SECRET_KEY=

# Restrict CORS to your web origin(s) (JSON list). Defaults to ["*"].
# CORUSCANT_CORS_ORIGINS=["http://localhost:8080"]

# Fail closed on unsafe config. When true, the app REFUSES to boot with wildcard
# CORS or an unset secret (instead of warning + degrading). Turn on in production.
# CORUSCANT_PRODUCTION=true

# --- Public launch (Phase 6) -----------------------------------------------
# Expose the safe, read-only public surface (entity search, profiles, relationships,
# timelines, evidence) to unauthenticated visitors — no forced sign-in. ON by
# default; set false to re-gate discovery to authenticated-only.
# CORUSCANT_PUBLIC_READ=true
# Anonymous requests/minute per client IP against the public surface (signed-in
# callers are exempt). Coarse anti-abuse; 0 disables limiting (flagged in production).
# CORUSCANT_PUBLIC_READ_RATE_LIMIT=120

# --- Rate-limit deployment hardening (Phase 7) -----------------------------
# Trust X-Forwarded-For when deriving the rate-limit client IP. OFF by default (the
# socket peer is used, so a client cannot spoof its identity). Turn ON only when a
# TRUSTED reverse proxy sets the header (e.g. nginx in the compose topology).
# CORUSCANT_TRUST_FORWARDED_FOR=true
# Rate-limit backend. "memory" (default): in-process, correct for a single instance.
# A shared/distributed backend (e.g. Redis) is a seam in coruscant.apps.ratelimit;
# selecting an unimplemented backend fails closed instead of limiting per-instance.
# CORUSCANT_RATE_LIMIT_BACKEND=memory

# Demo account seeding is OFF by default. For a local demo only, opt in and set
# a password (the docker-compose stack does this for you):
# CORUSCANT_SEED_DEMO_USER=true
# CORUSCANT_DEMO_PASSWORD=change-me

# Expose password-reset tokens in the API response (offline/dev only; never prod).
# CORUSCANT_EXPOSE_RESET_TOKEN=false

# --- Live ingestion (production) -------------------------------------------
# Sources that use their real network connector instead of the offline reference
# connector (JSON list). Empty by default → dev/test stay fully offline. Only
# sec_edgar currently has a live connector. For the live path to fetch anything,
# the relevant companies must declare `sec_filings:` URLs in config/companies.yml.
# CORUSCANT_LIVE_SOURCES=["sec_edgar"]

# SEC requires a contact-bearing User-Agent on every request.
# CORUSCANT_EDGAR_USER_AGENT=YourCompany/1.0 you@example.com

# SEC fair-access cap (requests/second; SEC permits ~10). Applies to live EDGAR.
# CORUSCANT_SEC_RATE_LIMIT_PER_SECOND=8

# Live equity quotes for the World tab "since yesterday" (free Yahoo Finance,
# unofficial/not real-time). OFF by default so offline/test never hits the
# network; when off, /portfolio/prices reports connected=false (never faked).
# CORUSCANT_ENABLE_LIVE_PRICES=true

# Live country macro for the World tab (free World Bank GDP/inflation + Yahoo
# benchmark-index move). OFF by default; gated separately from prices because the
# World Bank API is slower/flakier. When off, /macro reports connected=false.
# CORUSCANT_ENABLE_LIVE_MACRO=true

# Live business-news headlines for the World tab (free GDELT DOC API, no key).
# OFF by default; GDELT rate-limits hard per IP, so the service gates our request
# rate and caches. When off, /news reports connected=false (never faked headlines).
# CORUSCANT_ENABLE_LIVE_NEWS=true

# --- Multi-tenant quota enforcement ----------------------------------------
# Enforce per-plan daily API + watchlist limits. Only takes effect when an
# organization store is configured (a multi-tenant deployment); single-tenant
# use is never throttled. Set false to disable.
# CORUSCANT_ENFORCE_QUOTAS=true
